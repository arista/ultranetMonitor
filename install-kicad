#!/bin/bash

# Fail on command failure, undefined variables, and piped command failures
set -euo pipefail
export DEBIAN_FRONTEND=noninteractive

# Versions to install
export EASYEDA2KICAD_VERSION=1.0.1   # check https://pypi.org/project/easyeda2kicad/ for newer

# --- KiCad 9 -----------------------------------------------------------------
# Ubuntu 24.04's own repo only ships KiCad 8; use the official PPA for 9.x.
apt-get update
apt-get install -y --no-install-recommends software-properties-common
add-apt-repository -y ppa:kicad/kicad-9.0-releases
apt-get update
# Drop "kicad-libraries" if you only ever use your own libraries — it's large
# (official symbols/footprints/3D models). The "kicad" metapackage pulls it in
# by default, so installing it explicitly just makes the intent clear.
apt-get install -y --no-install-recommends kicad kicad-libraries

# --- easyeda2kicad ------------------------------------------------------------
# CLI tool that pulls a part's symbol + footprint + 3D .step from any LCSC id:
#   easyeda2kicad --full --lcsc_id C2040
# Installed via pipx (isolated venv) because Ubuntu 24.04 enforces PEP 668 and
# refuses system-wide `pip install`. pipx itself comes from install-base-utils.
# PIPX_BIN_DIR puts the launcher on the global PATH so every user/shell can run
# `easyeda2kicad`.
export PIPX_HOME=/opt/pipx
export PIPX_BIN_DIR=/usr/local/bin
pipx install "easyeda2kicad==${EASYEDA2KICAD_VERSION}"

# --- KiCad plugins (manual step, not scripted) -------------------------------
# The JLCPCB workflow plugins live in KiCad's Plugin & Content Manager, which is
# a GUI/per-user-config thing — install them once from inside KiCad rather than
# baking into the image:
#   * "JLCPCB tools" (Bouni)        - assign LCSC part #s, search the catalog,
#                                     generate Gerber/BOM/CPL for PCBA ordering
#   * "Fabrication Toolkit"         - simpler JLCPCB production-file generator
# Open KiCad -> Plugins -> Plugin and Content Manager -> search & install.

# --- cleanup ------------------------------------------------------------------
rm -rf /var/lib/apt/lists/*
